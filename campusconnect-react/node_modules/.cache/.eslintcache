,"column":9,"nodeType":"137","messageId":"145","endLine":67,"endColumn":18,"suppressions":"146"},"no-use-before-define","'fetchInternships' was used before it was defined.","Identifier","usedBeforeDefined","react-hooks/exhaustive-deps","The 'fetchInternships' function makes the dependencies of useEffect Hook (at line 18) change on every render. To fix this, wrap the definition of 'fetchInternships' in its own useCallback() Hook.","VariableDeclarator",["147"],"no-unused-vars","'isStudent' is assigned a value but never used.","unusedVar",["148"],{"desc":"149","fix":"150"},{"kind":"151","justification":"152"},"Wrap the definition of 'fetchInternships' in its own useCallback() Hook.",{"range":"153","text":"154"},"directive","",[778,1304],"useCallback(async () => {\r\n    try {\r\n      const res = await fetch(\"/api/internships\");\r\n      const data = await res.json();\r\n      setInternships(data);\r\n\r\n      if (currentUser?.role === \"student\") {\r\n        const appRes = await fetch(`/api/applications/${currentUser._id}`);\r\n        const appData = await appRes.json();\r\n        const appliedIds = appData.map((app) => app.internshipId);\r\n        setAppliedInternships(appliedIds);\r\n      }\r\n    } catch (err) {\r\n      console.error(\"Error fetching internships:\", err);\r\n    }\r\n  })"]